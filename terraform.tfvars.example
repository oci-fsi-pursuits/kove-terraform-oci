# Copy to terraform.tfvars (gitignored) and edit. Terraform loads terraform.tfvars automatically.
# For RHSM passwords: use secrets.auto.tfvars (gitignored) or TF_VAR_* — see OCI-RESOURCE-MANAGER-GUIDE.md section 9.
# Head→BM Ansible uses the Terraform-generated ED25519 key (embedded in bootstrap); no ssh_private_key variable.

tenancy_ocid     = "ocid1.tenancy.oc1..aaaaaaaa..."
region           = "us-phoenix-1"
compartment_ocid = "ocid1.compartment.oc1..aaaaaaaa..."

ssh_public_key = <<-EOT
ssh-ed25519 AAAA... your-comment
EOT

bm_node_image_ocid   = "ocid1.image.oc1.phx.aaaaaaaa..."
head_node_image_ocid = ""

use_existing_vcn = true
existing_vcn_id            = "ocid1.vcn.oc1.phx.aaaaaaaa..."
existing_public_subnet_id  = "ocid1.subnet.oc1.phx.aaaaaaaa..."
existing_private_subnet_id = "ocid1.subnet.oc1.phx.aaaaaaaa..."

cluster_network_availability_domain = ""
# oci-hpc parity: false if custom RHEL + pool shows "Launched 0 of N" (HPC agent plugins); keep true for Oracle Linux HPC images.
use_compute_agent = true

cluster_display_name_prefix  = "bm"
bm_capacity_reservation_id   = ""
bm_generic_platform_config   = false

bm_node_count                  = 4
# Empty = 2h default per BM instance create. Override e.g. "3h" for slow regions.
cluster_network_create_timeout = ""
bm_pool_ready_wait             = "10m"
bm_boot_volume_size_gbs        = 120

# true (default): cloud-init creates /opt/oci-hpc-ansible on first boot. false = no user_data on head.
# After changing this on an existing stack, replace the head: terraform apply -replace=oci_core_instance.head_node
run_ansible_from_head = true
rhsm_username         = ""
rhsm_password         = ""
rdma_ping_target      = ""

instance_ssh_user  = "cloud-user"
head_node_ssh_user = "opc"
